rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['title', 'createdAt', 'updatedAt', 'userId']) &&
             data.title is string && data.title.size() <= 100 &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (!('pinned' in data) || data.pinned is bool) &&
             data.userId == request.auth.uid;
    }

    function isValidMessage(data, sessionId) {
      return data.keys().hasAll(['role', 'content', 'timestamp', 'sessionId', 'userId']) &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp is number &&
             data.sessionId == sessionId &&
             data.userId == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isDocOwner() && isValidSession(request.resource.data);
      allow delete: if isDocOwner();
      
      match /messages/{messageId} {
        function isSessionOwner() {
          return isAuthenticated() && 
                 exists(/databases/$(database)/documents/sessions/$(sessionId)) && 
                 get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        }
        
        allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow create: if isSessionOwner() && isValidMessage(request.resource.data, sessionId);
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidMessage(request.resource.data, sessionId);
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
